{
  "name": "bond",
  "version": "0.1.0",
  "description": "Bond — local Electron agent using the Claude Agent SDK",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "npm run build:daemon && electron-vite dev",
    "build": "electron-vite build && npm run build:daemon",
    "build:daemon": "esbuild src/daemon/main.ts --bundle --platform=node --format=esm --outfile=out/daemon/main.mjs --external:@anthropic-ai/claude-agent-sdk --external:better-sqlite3 --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "preview": "electron-vite preview",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.86",
    "@phosphor-icons/vue": "^2.2.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "better-sqlite3": "^12.8.0",
    "dompurify": "^3.3.3",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "happy-dom": "^20.8.9",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.5",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^7.3.1",
    "vitest": "^4.1.2",
    "vue": "^3.5.31"
  },
  "dependencies": {
    "ws": "^8.20.0"
  }
}
