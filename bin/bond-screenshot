#!/usr/bin/env node

import { chromium } from 'playwright'
import { createServer as createHttpServer, request as httpRequest } from 'node:http'
import { writeFileSync, mkdirSync } from 'node:fs'
import { join } from 'node:path'
import { homedir } from 'node:os'

// --- Arg parsing ---

const args = process.argv.slice(2)

function getFlag(name) {
  const idx = args.indexOf(`--${name}`)
  if (idx === -1 || idx + 1 >= args.length) return undefined
  return args[idx + 1]
}

const url = getFlag('url')
const viewport = getFlag('viewport') || 'desktop'
const screenshotDir = join(homedir(), 'Library', 'Application Support', 'bond', 'screenshots')
mkdirSync(screenshotDir, { recursive: true })
const output = getFlag('output') || join(screenshotDir, `screenshot-${Date.now()}.png`)

if (!url) {
  console.error('Usage: bond-screenshot --url <url> [--viewport desktop|mobile] [--output <path>]')
  process.exit(1)
}

const VIEWPORTS = {
  desktop: { width: 1040, height: 1248 },
  mobile: { width: 390, height: 844 }
}

const vp = VIEWPORTS[viewport]
if (!vp) {
  console.error(`Invalid viewport "${viewport}". Use "desktop" or "mobile".`)
  process.exit(1)
}

// --- WordPress custom domain proxy ---
// WordPress Studio sites with custom domains (e.g. my-site.wp.local) route through
// Studio's port 80 proxy, which chokes under 30+ concurrent requests from a page load.
// We run a local proxy that sends requests directly to the Studio port with the correct
// Host header, bypassing the port 80 bottleneck entirely. Playwright routes all requests
// for the custom domain through this proxy.

const parsedUrl = new URL(url)
const isCustomDomain = parsedUrl.hostname !== 'localhost' && parsedUrl.hostname !== '127.0.0.1'
const targetHost = parsedUrl.hostname
const targetPort = parseInt(parsedUrl.port) || 80

function startProxy(host, port) {
  return new Promise((resolve) => {
    const proxy = createHttpServer((clientReq, clientRes) => {
      const proxyReq = httpRequest({
        hostname: '127.0.0.1',
        port: port,
        path: clientReq.url,
        method: clientReq.method,
        headers: { ...clientReq.headers, host: host },
      }, (proxyRes) => {
        // Rewrite Location headers that point to the custom domain
        const headers = { ...proxyRes.headers }
        if (headers.location) {
          try {
            const loc = new URL(headers.location, `http://${host}`)
            if (loc.hostname === host && (!loc.port || loc.port === '80')) {
              loc.hostname = 'localhost'
              loc.port = proxy.address().port
              headers.location = loc.toString()
            }
          } catch { /* leave it */ }
        }
        clientRes.writeHead(proxyRes.statusCode, headers)
        proxyRes.pipe(clientRes)
      })
      proxyReq.on('error', () => clientRes.destroy())
      clientReq.pipe(proxyReq)
    })
    // Allow lots of concurrent connections
    proxy.maxConnections = 100
    proxy.listen(0, '127.0.0.1', () => {
      resolve({ proxy, port: proxy.address().port })
    })
  })
}

// --- Browser + screenshot ---

let browser
let proxyServer
try {
  let browseUrl = url
  let proxyPort

  if (isCustomDomain) {
    const p = await startProxy(targetHost, targetPort)
    proxyServer = p.proxy
    proxyPort = p.port
    browseUrl = `http://localhost:${proxyPort}${parsedUrl.pathname}${parsedUrl.search}`
  }

  browser = await chromium.launch({ headless: true })
  const page = await browser.newPage({ viewport: vp })

  // Reduce motion to avoid capturing mid-animation states
  await page.emulateMedia({ reducedMotion: 'reduce' })

  // Route all custom domain requests through our proxy
  if (isCustomDomain && proxyPort) {
    await page.route(`**://${targetHost}/**`, (route) => {
      const reqUrl = new URL(route.request().url())
      reqUrl.hostname = 'localhost'
      reqUrl.port = proxyPort
      reqUrl.protocol = 'http:'
      route.continue({ url: reqUrl.toString() })
    })
  }

  // Navigate and wait for network idle
  await page.goto(browseUrl, { waitUntil: 'networkidle', timeout: 15_000 })

  // Wait for all images to finish loading
  await page.evaluate(() =>
    Promise.all(
      Array.from(document.images)
        .filter(img => !img.complete)
        .map(img => new Promise(resolve => {
          img.addEventListener('load', () => resolve())
          img.addEventListener('error', () => resolve())
        }))
    )
  )

  // Hide WP admin bar and scrollbars for clean screenshots
  await page.addStyleTag({
    content: `
      #wpadminbar { display: none !important; }
      html { margin-top: 0 !important; }
      ::-webkit-scrollbar { display: none !important; }
      html, body { scrollbar-width: none !important; }
    `
  })

  // Capture full-page screenshot
  const buffer = await page.screenshot({ fullPage: true, type: 'png' })
  writeFileSync(output, buffer)

  console.log(output)
} catch (err) {
  console.error(`Screenshot failed: ${err.message}`)
  process.exit(1)
} finally {
  if (browser) await browser.close()
  if (proxyServer) proxyServer.close()
}
