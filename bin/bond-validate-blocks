#!/usr/bin/env node

import { chromium } from 'playwright'
import { readFileSync } from 'node:fs'

// --- Arg parsing ---

const args = process.argv.slice(2)

function getFlag(name) {
  const idx = args.indexOf(`--${name}`)
  if (idx === -1 || idx + 1 >= args.length) return undefined
  return args[idx + 1]
}

const siteUrl = getFlag('url')
const filePath = getFlag('file')
const inlineContent = getFlag('content')

if (!siteUrl) {
  console.error('Usage: bond-validate-blocks --url <site-url> [--file <path> | --content <html>]')
  process.exit(1)
}

if (!filePath && !inlineContent) {
  console.error('Provide --file <path> or --content <html>')
  process.exit(1)
}

const content = filePath ? readFileSync(filePath, 'utf-8') : inlineContent

// --- Browser + validation ---

let browser
try {
  browser = await chromium.launch({
    headless: true,
    args: ['--ignore-certificate-errors']
  })

  const page = await browser.newPage({ ignoreHTTPSErrors: true })

  // Navigate to WP block editor via auto-login
  const loginUrl = `${siteUrl.replace(/\/$/, '')}/studio-auto-login?redirect_to=/wp-admin/post-new.php`
  await page.goto(loginUrl, { waitUntil: 'domcontentloaded', timeout: 30_000 })

  // Wait for wp.blocks to be ready with registered block types
  await page.waitForFunction(() => {
    try {
      const wp = window.wp
      return wp && wp.blocks && typeof wp.blocks.getBlockTypes === 'function' && wp.blocks.getBlockTypes().length > 0
    } catch { return false }
  }, { timeout: 30_000 })

  // Run validation in the browser
  const report = await page.evaluate((html) => {
    const wpBlocks = window.wp?.blocks
    if (!wpBlocks) {
      return { totalBlocks: 0, validBlocks: 0, invalidBlocks: 0, results: [], error: 'wp.blocks is not available' }
    }

    const blocks = wpBlocks.parse(html)
    const results = []

    function extractIssues(validationIssues) {
      const issues = []
      for (const issue of validationIssues) {
        if (issue?.args) {
          const msg = String(issue.args[0] || '')
          if (!msg.startsWith('Block validation failed')) {
            issues.push(issue.args.map(a => typeof a === 'object' ? JSON.stringify(a).slice(0, 200) : String(a).slice(0, 500)).join(' '))
          }
        }
      }
      return issues
    }

    function validateRecursive(block) {
      if (!block.name) return
      if (block.name === 'core/freeform' || block.name === 'core/missing') return

      const blockType = wpBlocks.getBlockType(block.name)
      let issues = []
      let isValid = true
      let expectedContent

      if (!blockType) {
        isValid = false
        issues.push(`Block type "${block.name}" is not registered. It may require a plugin that is not active.`)
      } else {
        const validation = wpBlocks.validateBlock(block, blockType)

        if (Array.isArray(validation)) {
          isValid = validation[0]
          if (!isValid) issues = extractIssues(validation[1] || [])
        } else {
          isValid = validation.isValid
          if (!isValid) issues = extractIssues(validation.validationIssues || [])
        }

        if (!isValid) {
          try {
            expectedContent = wpBlocks.getSaveContent(blockType, block.attributes, block.innerBlocks)
          } catch { /* skip */ }
        }
      }

      results.push({
        blockName: block.name,
        isValid,
        issues,
        originalContent: block.originalContent || '',
        expectedContent: isValid ? undefined : expectedContent
      })

      if (block.innerBlocks) {
        for (const inner of block.innerBlocks) validateRecursive(inner)
      }
    }

    for (const block of blocks) validateRecursive(block)

    const validCount = results.filter(r => r.isValid).length
    return {
      totalBlocks: results.length,
      validBlocks: validCount,
      invalidBlocks: results.length - validCount,
      results
    }
  }, content)

  console.log(JSON.stringify(report, null, 2))
} catch (err) {
  console.log(JSON.stringify({
    totalBlocks: 0,
    validBlocks: 0,
    invalidBlocks: 0,
    results: [],
    error: `Block validation error: ${err.message}`
  }, null, 2))
  process.exit(1)
} finally {
  if (browser) await browser.close()
}
